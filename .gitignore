```gitignore
# ----------------------
# Binaries
# ----------------------
*.exe
*.exe~
*.dll
*.so
*.dylib

# ----------------------
# Test binaries
# ----------------------
*.test

# ----------------------
# Build output
# ----------------------
bin/
build/
dist/

# ----------------------
# Go workspace
# ----------------------
go.work
go.work.sum

# ----------------------
# Dependencies (обычно НЕ игнорят go.mod/sum)
# ----------------------
vendor/

# ----------------------
# Logs
# ----------------------
*.log

# ----------------------
# Environment
# ----------------------
.env
.env.*

# ----------------------
# IDE / Editors
# ----------------------
.vscode/
.idea/

# ----------------------
# OS files
# ----------------------
.DS_Store
Thumbs.db

# ----------------------
# Coverage
# ----------------------
coverage.out
*.coverprofile

# ----------------------
# Temporary
# ----------------------
tmp/
*.tmp
```
